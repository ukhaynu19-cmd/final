<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Edit Exam Entry</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/admin-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Edit Exam Entry</h1>
    <div class="panel">
      <form method="POST" action="/admin/exams/edit/<%= entry._id %>">
        <div class="form-row">
          <div class="field"><label>Class</label>
            <select name="class" id="exe-class"><% db.classes.forEach(c=>{ %><option <%= c===entry.class?'selected':'' %>><%=c%></option><% }) %></select>
          </div>
          <div class="field"><label>Section / Group</label>
            <select name="section" id="exe-section"></select>
          </div>
          <div class="field"><label>Exam Name</label><input name="examName" value="<%= entry.examName %>" required></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Subject</label><input name="subject" value="<%= entry.subject %>" required></div>
          <div class="field"><label>Date</label><input type="date" name="date" value="<%= entry.date %>" required></div>
          <div class="field"><label>Time</label><input name="time" value="<%= entry.time %>" required></div>
        </div>
        <button class="btn btn-primary" style="width:auto;" type="submit">Save Changes</button>
        <a href="/admin/exams" class="btn btn-secondary" style="width:auto;margin-left:8px;">Cancel</a>
      </form>
    </div>
  </div>
</div>
<script src="/js/class-sections.js"></script>
<script>
  setupClassSectionSync(
    document.getElementById('exe-class'),
    document.getElementById('exe-section'),
    <%- JSON.stringify(db.classSections) %>,
    <%- JSON.stringify(entry.section || '') %>
  );
</script>
</body></html>
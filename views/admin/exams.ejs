<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Exam Routine</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/admin-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Exam Routine</h1>
    <div class="page-sub">Schedule exams per class/section</div>

    <div class="panel">
      <h3>Add Exam Entry</h3>
      <form method="POST" action="/admin/exams/add">
        <div class="form-row">
          <div class="field"><label>Class</label><select name="class" id="ex-class"><% db.classes.forEach(c=>{ %><option><%=c%></option><% }) %></select></div>
          <div class="field"><label>Section / Group</label><select name="section" id="ex-section"></select></div>
          <div class="field"><label>Exam Name</label><input name="examName" placeholder="Half Yearly 2026" required></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Subject</label><input name="subject" required></div>
          <div class="field"><label>Date</label><input type="date" name="date" required></div>
          <div class="field"><label>Time</label><input name="time" placeholder="10:00 AM - 1:00 PM" required></div>
        </div>
        <button class="btn btn-primary" style="width:auto;" type="submit">Add Exam</button>
      </form>
    </div>

    <div class="panel">
      <h3>Exam Schedule</h3>
      <table>
        <tr><th>Class</th><th>Sec/Group</th><th>Exam</th><th>Subject</th><th>Date</th><th>Time</th><th></th></tr>
        <% db.examRoutines.forEach((e,i) => { %>
        <tr>
          <td><%= e.class %></td><td><%= e.section || '—' %></td><td><%= e.examName %></td><td><%= e.subject %></td>
          <td><%= e.date %></td><td><%= e.time %></td>
          <td>
            <a href="/admin/exams/edit/<%= e._id %>" class="btn btn-secondary" style="padding:5px 10px;font-size:0.75rem;">Edit</a>
            <form method="POST" action="/admin/exams/delete/<%= e._id %>" style="display:inline">
              <button class="btn btn-danger" style="padding:5px 10px;font-size:0.75rem;" type="submit">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </table>
    </div>
  </div>
</div>
<script src="/js/class-sections.js"></script>
<script>
  setupClassSectionSync(
    document.getElementById('ex-class'),
    document.getElementById('ex-section'),
    <%- JSON.stringify(db.classSections) %>,
    null
  );
</script>
</body></html>
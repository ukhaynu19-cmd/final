<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Results</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/admin-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Exam Results</h1>
    <div class="page-sub">Enter marks per student per subject</div>

    <div class="panel">
      <h3>Add / Update Score</h3>
      <div class="readonly-note" style="margin-bottom:16px;">Pick a class first to narrow down the student list. Set a Publish Date to control when the score becomes visible to the student and guardian — leave blank to publish immediately. Adding the same student + exam + subject again updates the existing score instead of duplicating it.</div>
      <form method="POST" action="/admin/results/add">
        <div class="form-row">
          <div class="field"><label>Class</label>
            <select id="res-class">
              <% db.classes.forEach(c=>{ %><option value="<%= c %>"><%= c %></option><% }) %>
            </select>
          </div>
          <div class="field"><label>Student</label>
            <select name="studentId" id="res-student"></select>
          </div>
          <div class="field"><label>Exam Name</label><input name="examName" placeholder="Half Yearly 2026" required></div>
          <div class="field"><label>Subject</label><input name="subject" required></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Full Marks</label><input type="number" name="fullMarks" value="100" required></div>
          <div class="field"><label>Obtained</label><input type="number" name="obtained" required></div>
          <div class="field"><label>Publish Date</label><input type="date" name="publishDate"></div>
        </div>
        <button class="btn btn-primary" style="width:auto;" type="submit">Save Score</button>
      </form>
    </div>

    <div class="panel">
      <h3>All Results</h3>
      <table>
        <tr><th>Student</th><th>Exam</th><th>Subject</th><th>Marks</th><th>Publish Date</th><th></th></tr>
        <% db.results.forEach((r,i) => { const s = db.students.find(x=>x.id===r.studentId);
           const today = new Date().toISOString().slice(0,10);
           const isFuture = r.publishDate && r.publishDate > today; %>
        <tr>
          <td><%= s ? s.name : r.studentId %></td><td><%= r.examName %></td><td><%= r.subject %></td>
          <td><%= r.obtained %> / <%= r.fullMarks %></td>
          <td>
            <% if (!r.publishDate) { %><span class="badge badge-paid">Published now</span>
            <% } else if (isFuture) { %><span class="badge badge-due"><%= r.publishDate %> (scheduled)</span>
            <% } else { %><span class="badge badge-paid"><%= r.publishDate %></span><% } %>
          </td>
          <td>
            <a href="/admin/results/edit/<%= r._id %>" class="btn btn-secondary" style="padding:5px 10px;font-size:0.75rem;">Edit</a>
            <form method="POST" action="/admin/results/delete/<%= r._id %>" style="display:inline" onsubmit="return confirm('Delete this result?')">
              <button class="btn btn-danger" style="padding:5px 10px;font-size:0.75rem;" type="submit">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </table>
    </div>
  </div>
</div>
<script src="/js/class-students.js"></script>
<script>
  setupClassStudentSync(
    document.getElementById('res-class'),
    document.getElementById('res-student'),
    <%- JSON.stringify(db.students.map(s => ({ id: s.id, name: s.name, class: s.class, section: s.section }))) %>,
    null
  );
</script>
</body></html>
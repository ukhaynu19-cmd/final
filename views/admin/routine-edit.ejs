<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Edit Routine Entry</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/admin-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Edit Routine Entry</h1>
    <div class="panel">
      <form method="POST" action="/admin/routine/edit/<%= entry._id %>">
        <div class="form-row">
          <div class="field"><label>Class</label>
            <select name="class" id="rte-class"><% db.classes.forEach(c=>{ %><option <%= c===entry.class?'selected':'' %>><%=c%></option><% }) %></select>
          </div>
          <div class="field"><label>Section / Group</label>
            <select name="section" id="rte-section"></select>
          </div>
          <div class="field"><label>Day</label>
  <select name="day">
    <% dayOrder.forEach(d=>{ %><option <%= d===entry.day?'selected':'' %>><%=d%></option><% }) %>
  </select>
</div>
          <div class="field"><label>Period</label><input name="period" value="<%= entry.period %>" required></div>
        </div>
        <div class="form-row">
          <div class="field"><label>Time</label><input name="time" value="<%= entry.time %>" required></div>
          <div class="field"><label>Subject</label><input name="subject" value="<%= entry.subject %>" required></div>
          <div class="field"><label>Teacher</label>
            <select name="teacherId">
              <% (db.teachers || []).forEach(t=>{ %><option value="<%= t.id %>" <%= t.id===entry.teacherId?'selected':'' %>><%= t.name %> (<%= t.subjects.join(', ') %>)</option><% }) %>
            </select>
          </div>
        </div>
        <button class="btn btn-primary" style="width:auto;" type="submit">Save Changes</button>
        <a href="/admin/routine" class="btn btn-secondary" style="width:auto;margin-left:8px;">Cancel</a>
      </form>
    </div>
  </div>
</div>
<script src="/js/class-sections.js"></script>
<script>
  setupClassSectionSync(
    document.getElementById('rte-class'),
    document.getElementById('rte-section'),
    <%- JSON.stringify(db.classSections) %>,
    <%- JSON.stringify(entry.section || '') %>
  );
</script>
</body></html>
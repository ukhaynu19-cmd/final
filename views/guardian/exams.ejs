<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Exam Routine</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/guardian-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Exam Routine</h1>
    <div class="page-sub">Class <%= student.class %><%= student.section ? ' · Group ' + student.section : '' %></div>

    <div class="panel">
      <% if (examRoutine.length === 0) { %><p style="color:var(--muted)">No exams scheduled.</p><% } else { %>
      <table>
        <tr><th>Exam</th><th>Subject</th><th>Date</th><th>Time</th></tr>
        <% examRoutine.forEach(e => { %>
        <tr><td><%= e.examName %></td><td><%= e.subject %></td><td><%= e.date %></td><td><%= e.time %></td></tr>
        <% }) %>
      </table>
      <% } %>
    </div>
  </div>
</div>
</body></html>

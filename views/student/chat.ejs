<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Live Chat</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/student-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Live Chat</h1>
    <div class="page-sub">Chat with your teachers and classmates — everyone can see this</div>

    <div class="panel">
      <div id="chat-messages" style="height:60vh; overflow-y:auto; display:flex; flex-direction:column; padding:10px; border:1px solid rgba(255,255,255,0.08); border-radius:8px; margin-bottom:14px;">
        <% messages.forEach(m => { %>
          <div style="margin-bottom:10px; display:flex; flex-direction:column; align-items:<%= (m.senderRole==='student' && m.senderId===student.id) ? 'flex-end' : 'flex-start' %>;">
            <div style="font-size:0.72rem; color:var(--muted); margin-bottom:2px;">
              <%= m.senderName %> <span style="opacity:0.7;">(<%= m.senderRole.charAt(0).toUpperCase() + m.senderRole.slice(1) %>)</span>
              · <%= new Date(m.createdAt).toLocaleString([], { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) %>
            </div>
            <div style="max-width:75%; padding:8px 12px; border-radius:10px; background:<%= (m.senderRole==='student' && m.senderId===student.id) ? 'var(--accent, #2e7d5b)' : 'rgba(255,255,255,0.08)' %>; color:<%= (m.senderRole==='student' && m.senderId===student.id) ? '#fff' : 'inherit' %>;">
              <%= m.message %>
            </div>
          </div>
        <% }) %>
      </div>

      <form id="chat-form" style="display:flex; gap:8px;">
        <input id="chat-input" type="text" placeholder="Type a message..." autocomplete="off" required style="flex:1;">
        <button class="btn btn-primary" style="width:auto;" type="submit">Send</button>
      </form>
    </div>
  </div>
</div>

<script>
  window.chatCurrentSenderId = "<%= student.id %>";
  window.chatCurrentRole = "student";
  <% if (messages.length > 0) { %>
    window.chatInitialLastTime = "<%= messages[messages.length - 1].createdAt.toISOString() %>";
  <% } %>
</script>
<script src="/js/group-chat.js"></script>
</body></html>

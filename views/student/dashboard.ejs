<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Student Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/student-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Welcome, <%= student.name %></h1>
    <div class="page-sub">Class <%= student.class %><%= student.section ? ' · Group ' + student.section : '' %> · Roll <%= student.roll %> · ID <%= student.id %></div>

    <div class="stat-grid">
      <div class="stat-card"><div class="label">Attendance</div><div class="value"><%= attendance.percent %>%</div></div>
      <div class="stat-card"><div class="label">Present</div><div class="value">Present</div><div class="value" style="font-size:1.3rem;"><%= attendance.present %> days</div></div>
      <div class="stat-card"><div class="label">Absent</div><div class="value clay"><%= attendance.absent %> days</div></div>
      <div class="stat-card"><div class="label">Fees Due</div><div class="value gold"><%= fees.filter(f=>f.status!=='Paid').length %></div></div>
    </div>

    <div class="panel">
      <h3>Upcoming Exams</h3>
      <% if (examRoutine.length === 0) { %><p style="color:var(--muted)">No exams scheduled.</p><% } else { %>
      <table>
        <tr><th>Exam</th><th>Subject</th><th>Date</th><th>Time</th></tr>
        <% examRoutine.forEach(e => { %>
        <tr><td><%= e.examName %></td><td><%= e.subject %></td><td><%= e.date %></td><td><%= e.time %></td></tr>
        <% }) %>
      </table>
      <% } %>
    </div>
  </div>
</div>
</body></html>

<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>My Results</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/student-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">My Results</h1>
    <div class="page-sub"><%= student.name %> — Class <%= student.class %><%= student.section ? ' - ' + student.section : '' %></div>

    <div class="panel">
      <% if (results.length === 0) { %><p style="color:var(--muted)">No results published yet.</p><% } else { %>
      <table>
        <tr><th>Exam</th><th>Subject</th><th>Marks</th><th>%</th><th>Published</th></tr>
        <% results.forEach(r => { %>
        <tr>
          <td><%= r.examName %></td><td><%= r.subject %></td>
          <td><%= r.obtained %> / <%= r.fullMarks %></td>
          <td><%= Math.round((r.obtained / r.fullMarks) * 100) %>%</td>
          <td><%= r.publishDate || '—' %></td>
        </tr>
        <% }) %>
      </table>
      <% } %>
    </div>
  </div>
</div>
</body></html>

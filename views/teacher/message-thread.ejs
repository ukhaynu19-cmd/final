<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Chat with <%= student.name %></title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/teacher-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Chat with <%= student.name %></h1>
    <div class="page-sub"><%= student.id %> — Class <%= student.class %><%= student.section ? ' - ' + student.section : '' %></div>
    <div style="margin-bottom:14px;"><a href="/teacher/messages" style="color:var(--muted);">← Back to Messages</a></div>

    <div class="panel">
      <div style="height:55vh; overflow-y:auto; display:flex; flex-direction:column; padding:10px; border:1px solid rgba(255,255,255,0.08); border-radius:8px; margin-bottom:14px;">
        <% if (messages.length === 0) { %>
          <p style="color:var(--muted)">No messages yet. Send one below to start the conversation.</p>
        <% } %>
        <% messages.forEach(m => { %>
          <div style="margin-bottom:10px; display:flex; flex-direction:column; align-items:<%= m.senderRole==='teacher' ? 'flex-end' : 'flex-start' %>;">
            <div style="font-size:0.72rem; color:var(--muted); margin-bottom:2px;">
              <%= m.senderName %> · <%= new Date(m.createdAt).toLocaleString([], { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) %>
            </div>
            <div style="max-width:75%; padding:8px 12px; border-radius:10px; background:<%= m.senderRole==='teacher' ? 'var(--accent, #2e7d5b)' : 'rgba(255,255,255,0.08)' %>; color:<%= m.senderRole==='teacher' ? '#fff' : 'inherit' %>;">
              <%= m.message %>
            </div>
          </div>
        <% }) %>
      </div>

      <form method="POST" action="/teacher/messages/<%= student.id %>/send" style="display:flex; gap:8px;">
        <input name="message" type="text" placeholder="Type a message..." autocomplete="off" required style="flex:1;">
        <button class="btn btn-primary" style="width:auto;" type="submit">Send</button>
      </form>
    </div>
  </div>
</div>
</body></html>

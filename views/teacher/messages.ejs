<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>Messages</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/teacher-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">Messages</h1>
    <div class="page-sub">Private conversations with students. Any teacher can reply to any thread.</div>

    <div class="panel">
      <% if (threads.length === 0) { %>
        <p style="color:var(--muted)">No students yet.</p>
      <% } else { %>
      <table>
        <tr><th>Student</th><th>Class</th><th>Last Message</th><th>When</th><th></th></tr>
        <% threads.forEach(t => { %>
        <tr>
          <td><%= t.student.name %> (<%= t.student.id %>)</td>
          <td><%= t.student.class %><%= t.student.section ? ' - ' + t.student.section : '' %></td>
          <td>
            <% if (t.lastMessage) { %>
              <%= t.lastMessage.senderRole === 'student' ? '' : t.lastMessage.senderName + ': ' %><%= t.lastMessage.message.length > 40 ? t.lastMessage.message.slice(0,40) + '…' : t.lastMessage.message %>
            <% } else { %>
              <span style="color:var(--muted)">No messages yet</span>
            <% } %>
          </td>
          <td><%= t.lastMessage ? new Date(t.lastMessage.createdAt).toLocaleString([], { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '—' %></td>
          <td><a href="/teacher/messages/<%= t.student.id %>" class="btn btn-secondary" style="padding:5px 10px;font-size:0.75rem;">Open</a></td>
        </tr>
        <% }) %>
      </table>
      <% } %>
    </div>
  </div>
</div>
</body></html>

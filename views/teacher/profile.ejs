<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>My Profile</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="stylesheet" href="/css/style.css"></head>
<body>
<div class="app">
  <%- include('../partials/teacher-sidebar', { page }) %>
  <div class="main">
    <h1 class="page-title">My Profile</h1>
    <div class="page-sub">Teacher ID <%= teacher.id %></div>

    <% if (message) { %><div class="readonly-note"><%= message %></div><% } %>
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <div class="panel">
      <h3>Account Details</h3>
      <table>
        <tr><th>Name</th><td><%= teacher.name %></td></tr>
        <tr><th>Subjects</th><td><%= teacher.subjects.join(', ') || '—' %></td></tr>
        <tr><th>Phone</th><td><%= teacher.phone || '—' %></td></tr>
      </table>
    </div>
<div class="panel">
  <h3>My Photo</h3>
  <% if (teacher.photoUrl) { %>
    <img src="<%= teacher.photoUrl %>" style="width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:14px;display:block;">
  <% } %>
  <form method="POST" action="/teacher/profile/photo" enctype="multipart/form-data">
    <input type="file" name="photo" accept="image/*" required style="display:inline-block;width:auto;">
    <button class="btn btn-primary" style="width:auto;margin-top:0;" type="submit">Upload Photo</button>
  </form>
  <p style="color:var(--muted);font-size:0.8rem;margin-top:8px;">JPG or PNG, up to 5MB</p>
</div>
    <div class="panel">
      <h3>Change Password</h3>
      <form method="POST" action="/teacher/profile/change-password">
        <div class="form-row">
          <div class="field"><label>Current Password</label><input type="password" name="currentPassword" required></div>
          <div class="field"><label>New Password</label><input type="password" name="newPassword" required></div>
        </div>
        <button class="btn btn-primary" style="width:auto;" type="submit">Update Password</button>
      </form>
    </div>
  </div>
</div>
</body></html>
